-- 2) AMIRA TRANSFORMED (standardized)
CREATE OR REPLACE TABLE `topminnow.Pecos_Cyber_Academy.amira_transformed` AS
SELECT
  CURRENT_TIMESTAMP() AS load_timestamp,
  _FILE_NAME AS source_file,
  'AMIRA' AS assessment,

  -- from folder path like sy=2025-26
  REGEXP_EXTRACT(_FILE_NAME, r'sy=([0-9]{4}-[0-9]{2})') AS school_year_label,
  SAFE_CAST(SUBSTR(REGEXP_EXTRACT(_FILE_NAME, r'sy=([0-9]{4}-[0-9]{2})'), 1, 4) AS INT64) AS school_year_start,

  UPPER(REGEXP_EXTRACT(_FILE_NAME, r'window=([^/]+)')) AS testing_window,
  UPPER(REGEXP_EXTRACT(_FILE_NAME, r'window=([^/]+)')) AS testing_window_raw,

  -- If subject isn't in path, defaults to Reading for this file shape
  CASE
    WHEN LOWER(REGEXP_EXTRACT(_FILE_NAME, r'subject=([^/]+)')) = 'math' THEN 'Math'
    WHEN LOWER(REGEXP_EXTRACT(_FILE_NAME, r'subject=([^/]+)')) = 'reading' THEN 'Reading'
    ELSE 'Reading'
  END AS subject,
  UPPER(COALESCE(REGEXP_EXTRACT(_FILE_NAME, r'subject=([^/]+)'), 'READING')) AS subject_raw,

  SAFE_CAST(REGEXP_REPLACE(state_student_id, r'[^0-9]', '') AS INT64) AS student_id,
  INITCAP(TRIM(first_name)) AS first_name,
  INITCAP(TRIM(last_name)) AS last_name,
  CONCAT(INITCAP(TRIM(first_name)), ' ', INITCAP(TRIM(last_name))) AS student_name,
  SAFE_CAST(REGEXP_REPLACE(grade_level, r'[^0-9]', '') AS INT64) AS grade_level,
  grade_level AS grade_level_raw,

  CAST(NULL AS DATE) AS test_date,
  CAST(NULL AS STRING) AS school_name,
  CAST(NULL AS STRING) AS class_group,
  CAST(NULL AS INT64) AS cohort,

  -- standardized primary metrics
  SAFE_CAST(REGEXP_REPLACE(overall_reading_score, r'[^0-9.\\-]', '') AS FLOAT64) AS primary_score,
  SAFE_CAST(REGEXP_REPLACE(overall_reading_percentile, r'[^0-9.\\-]', '') AS FLOAT64) AS percentile,

  -- STAR-compatible aliases
  SAFE_CAST(REGEXP_REPLACE(overall_reading_score, r'[^0-9\\-]', '') AS INT64) AS scaled_score,
  SAFE_CAST(REGEXP_REPLACE(overall_reading_percentile, r'[^0-9\\-]', '') AS INT64) AS percentile_rank,
  CAST(NULL AS FLOAT64) AS grade_equivalent,

  -- Amira-specific fields (kept)
  overall_reading_tier,
  SAFE_CAST(REGEXP_REPLACE(listening_comprehension_score, r'[^0-9.\\-]', '') AS FLOAT64) AS listening_comprehension_score,
  listening_comprehension_tier,
  SAFE_CAST(REGEXP_REPLACE(listening_comprehension_percentile, r'[^0-9.\\-]', '') AS FLOAT64) AS listening_comprehension_percentile,
  SAFE_CAST(REGEXP_REPLACE(letter_knowledge_score, r'[^0-9.\\-]', '') AS FLOAT64) AS letter_knowledge_score,
  letter_knowledge_tier,
  SAFE_CAST(REGEXP_REPLACE(letter_knowledge_percentile, r'[^0-9.\\-]', '') AS FLOAT64) AS letter_knowledge_percentile,
  SAFE_CAST(REGEXP_REPLACE(phonemic_awareness_score, r'[^0-9.\\-]', '') AS FLOAT64) AS phonemic_awareness_score,
  phonemic_awareness_tier,
  SAFE_CAST(REGEXP_REPLACE(phonemic_awareness_percentile, r'[^0-9.\\-]', '') AS FLOAT64) AS phonemic_awareness_percentile
FROM `topminnow.Pecos_Cyber_Academy.amira-first-lake-table`
WHERE SAFE_CAST(REGEXP_REPLACE(state_student_id, r'[^0-9]', '') AS INT64) IS NOT NULL;
